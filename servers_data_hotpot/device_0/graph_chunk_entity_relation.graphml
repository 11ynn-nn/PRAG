  <data key="d0">"GEO"</data>
  <data key="d1">"Denmark is a country where cinnamon rolls are known as 'Kanelsnegl', a form of wienerbrød, and are widely consumed."</data>
  <data key="d2">chunk-a54a89950ff2fd3cb3d3a1223334b592</data>
</node>
<node id="&quot;NORTH AMERICA&quot;">
  <data key="d0">"GEO"</data>
