  <data key="d2">chunk-6d7a3e02dea60efd2006af1fc5b31d7c</data>
</node>
<node id="&quot;AIRBORNE TRANSMISSION&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"Airborne transmission is how the virus spreads through the environment."</data>
