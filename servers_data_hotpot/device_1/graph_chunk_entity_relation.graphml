</node>
<node id="&quot;NEWBORN CHICKS&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Newborn chicks are protected by maternal antibodies for a few weeks."</data>
  <data key="d2">chunk-6d7a3e02dea60efd2006af1fc5b31d7c</data>
</node>
<node id="&quot;VIRUSES&quot;">
  <data key="d0">"ORGANIZATION"</data>
