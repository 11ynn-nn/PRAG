</node>
<node id="&quot;GOLDEN HOUR&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"The Golden Hour is the period following injury when immediate care is crucial for trauma patients, a concept created by Dr. Cowley."</data>
  <data key="d2">chunk-b2821d62cd4c5aad9fe951ada9103c47</data>
  <data key="d3">[{"level": 0, "cluster": 24}, {"level": 1, "cluster": 116}]</data>
</node>
<node id="&quot;SOCIETY OF THORACIC SURGEONS&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Dr. Cowley founded the Society of Thoracic Surgeons, a professional organization for thoracic surgeons."</data>
  <data key="d2">chunk-b2821d62cd4c5aad9fe951ada9103c47</data>
