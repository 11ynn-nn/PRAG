  <data key="d3">[{"level": 0, "cluster": 1}, {"level": 1, "cluster": 35}]</data>
</node>
<node id="&quot;NEW YORK STATE PSYCHIATRIC INSTITUTE&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"New York State Psychiatric Institute is located in the Columbia University Medical Center in the Washington Heights neighborhood of Manhattan, New York City. It was established in 1895 and integrates teaching, research, and therapeutic approaches to the care of patients with mental illnesses. It affiliated with Presbyterian Hospital in 1925, now known as New York-Presbyterian Hospital."</data>
  <data key="d2">chunk-9e3843ca9496d241998ffa77892e9572</data>
  <data key="d3">[{"level": 0, "cluster": 1}, {"level": 1, "cluster": 36}]</data>
