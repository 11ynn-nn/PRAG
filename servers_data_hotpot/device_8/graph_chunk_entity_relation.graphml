  <data key="d2">chunk-da47f7fbfeff85b3d6a1641e3bae39b1&lt;SEP&gt;chunk-638820e59bfb7b6ae71fb76f6c2e0231</data>
</node>
<node id="&quot;ZEUTERIN&quot;">
  <data key="d0">"TECHNOLOGY"</data>
  <data key="d1">"Zeuterin is a trade name for an injectable product containing zinc gluconate and arginine, used for specific medical applications."&lt;SEP&gt;"Zeuterin is a trade name for an injectable product used for sterilizing young male dogs without removing the testicles, containing zinc gluconate and arginine."</data>
  <data key="d2">chunk-da47f7fbfeff85b3d6a1641e3bae39b1&lt;SEP&gt;chunk-638820e59bfb7b6ae71fb76f6c2e0231</data>
</node>
