<node id="&quot;MAINTENANCE ORGANIZATION&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"A maintenance organization provides health services for a fixed annual fee and acts as a liaison with health care providers on a prepaid basis."</data>
  <data key="d2">chunk-e33a24d622f5803fe7958f7fed2670a3</data>
  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 106}, {"level": 2, "cluster": 155}]</data>
