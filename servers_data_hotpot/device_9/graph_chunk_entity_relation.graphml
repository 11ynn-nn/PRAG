  <data key="d2">chunk-e33a24d622f5803fe7958f7fed2670a3</data>
  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 106}, {"level": 2, "cluster": 155}]</data>
</node>
<node id="&quot;FEDERALLY CERTIFIED HMO OPTIONS&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"The Health Maintenance Organization Act of 1973 required employers to offer federally certified HMO options."</data>
