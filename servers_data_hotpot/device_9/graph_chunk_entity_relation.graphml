<node id="&quot;HEALTH CARE PROVIDERS&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Health care providers include hospitals, doctors, and other professionals who have agreed by contract to treat patients in accordance with the HMO's guidelines and restrictions."</data>
  <data key="d2">chunk-e33a24d622f5803fe7958f7fed2670a3</data>
