  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Aetna Health Inc. is a private insurance company involved in the Aetna Health Inc. v. Davila case, providing health benefit plans through private employers."</data>
  <data key="d2">chunk-3131beff8473ac110bb6fe240fe57dbf</data>
  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 107}, {"level": 2, "cluster": 158}]</data>
