  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 107}, {"level": 2, "cluster": 157}, {"level": 3, "cluster": 159}]</data>
</node>
<node id="&quot;UTILIZATION REVIEW&quot;">
  <data key="d0">"ROLE"</data>
  <data key="d1">"Utilization Review involves evaluating the necessity and appropriateness of healthcare services provided to patients."</data>
  <data key="d2">chunk-3131beff8473ac110bb6fe240fe57dbf</data>
  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 107}, {"level": 2, "cluster": 157}, {"level": 3, "cluster": 159}]</data>
</node>
<node id="&quot;MANAGED CARE ENTITIES&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Managed Care Entities include organizations like CIGNA and Aetna that provide health care services through managed care plans."&lt;SEP&gt;"Managed Care entities refer to organizations like CIGNA and Aetna that make decisions on Case Management and Utilization Review."</data>
  <data key="d2">chunk-3131beff8473ac110bb6fe240fe57dbf&lt;SEP&gt;chunk-e9da95c787d3fcf42b176c577484a8ab</data>
  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 107}, {"level": 2, "cluster": 157}, {"level": 3, "cluster": 159}]</data>
</node>
<node id="&quot;HEALTH BENEFIT PLANS&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Health Benefit Plans are insurance products provided by private employers, often through managed care entities like Aetna and CIGNA."&lt;SEP&gt;"Health Benefit plans are insurance policies provided through private employers, which are subject to specific legal conditions regarding damages and enforcement."</data>
  <data key="d2">chunk-3131beff8473ac110bb6fe240fe57dbf&lt;SEP&gt;chunk-e9da95c787d3fcf42b176c577484a8ab</data>
