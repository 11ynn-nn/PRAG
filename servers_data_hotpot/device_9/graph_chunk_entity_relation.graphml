  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 106}, {"level": 2, "cluster": 155}]</data>
</node>
<node id="&quot;INDEMNITY INSURANCE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Indemnity insurance is a traditional form of health insurance that does not require a prepayment agreement with health care providers."</data>
  <data key="d2">chunk-e33a24d622f5803fe7958f7fed2670a3</data>
  <data key="d3">[{"level": 0, "cluster": 21}, {"level": 1, "cluster": 106}, {"level": 2, "cluster": 155}]</data>
</node>
<node id="&quot;MANAGED CARE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Managed Care refers to entities making medical decisions and can be held accountable for those decisions, especially in cases of negligence, as allowed by the Texas Healthcare Liability Act."&lt;SEP&gt;"Managed care is a system where health care providers are contracted to treat patients in exchange for a steady stream of customers."</data>
  <data key="d2">chunk-e40d0bd6c25f1a0f78cc71fd88f7b0ee&lt;SEP&gt;chunk-e33a24d622f5803fe7958f7fed2670a3</data>
