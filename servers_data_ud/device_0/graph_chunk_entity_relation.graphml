<edge source="&quot;AMERICAN MUSICAL THEATER&quot;" target="&quot;EXTRAVAGANZA&quot;">
  <data key="d4">5.0</data>
  <data key="d5">"Extravaganza influenced American musical theater with its grandiose and fantastical productions."&lt;</data>
  <data key="d6">chunk-289a23908915c5bcd0308dffe4b44213</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;AMERICAN MUSICAL THEATER&quot;" target="&quot;MINSTREL SHOW&quot;">
  <data key="d4">4.0</data>
