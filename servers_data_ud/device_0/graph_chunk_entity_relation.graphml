  <data key="d6">chunk-ec30e257221e71c474d6266d0784c302</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;FEDERAL&quot;" target="&quot;CONCEPT&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Federal laws can influence antitrust regulations at the national level in the United States."</data>
  <data key="d6">chunk-ec30e257221e71c474d6266d0784c302</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;STATE&quot;" target="&quot;CONCEPT&quot;">
