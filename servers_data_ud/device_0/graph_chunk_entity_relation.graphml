  <data key="d6">chunk-7b9cfa85a9917b7e3e3663f39bc8090b</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;HIVE BODIES&quot;" target="&quot;SOFTWOODS&quot;">
