  <data key="d4">9.0</data>
  <data key="d5">"Regulation in the organism includes the maintenance of acid-base balance as part of its overall regulatory processes."</data>
  <data key="d6">chunk-3d1f018f894ed3aab36e02fad8d45d76</data>
  <data key="d7">1</data>
</edge>
