  <data key="d4">6.0</data>
  <data key="d5">"European forms like opera, operetta, vaudeville, extravaganza, variety, burlesque, and minstrel shows have historically influenced American musical theater."&lt;</data>
  <data key="d6">chunk-289a23908915c5bcd0308dffe4b44213</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;AMERICAN MUSICAL THEATER&quot;" target="&quot;AMERICAN MUSICAL&quot;">
  <data key="d4">5.0</data>
  <data key="d5">"American Musical is a unique form of theatrical performance that developed in the United States, blending various European and modern styles."&lt;</data>
  <data key="d6">chunk-289a23908915c5bcd0308dffe4b44213</data>
  <data key="d7">1</data>
</edge>
