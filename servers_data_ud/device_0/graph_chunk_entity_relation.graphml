  <data key="d6">chunk-289a23908915c5bcd0308dffe4b44213</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;AMERICAN MUSICAL THEATER&quot;" target="&quot;VARIETY&quot;">
  <data key="d4">3.0</data>
  <data key="d5">"Variety shows influenced American musical theater with their wide range of acts."&lt;</data>
  <data key="d6">chunk-289a23908915c5bcd0308dffe4b44213</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;AMERICAN MUSICAL THEATER&quot;" target="&quot;POP/ROCK&quot;">
  <data key="d4">9.0</data>
  <data key="d5">"Pop/Rock became a prevalent style in American musical theater, especially on Broadway, during the 2012 period."&lt;</data>
  <data key="d6">chunk-289a23908915c5bcd0308dffe4b44213</data>
  <data key="d7">1</data>
</edge>
