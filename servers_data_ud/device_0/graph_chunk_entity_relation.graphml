  <data key="d6">chunk-16d39b19193e67d1a3c47d1a2851f964</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SINGERS&quot;" target="&quot;BRIGHTER SOUND&quot;">
  <data key="d4">16.0</data>
