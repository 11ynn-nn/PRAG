  <data key="d4">16.0</data>
  <data key="d5">"Package Colony is also suitable for new beekeepers, offering a manageable way to start beekeeping."</data>
  <data key="d6">chunk-6e8e292472440147bfd5caa5df68f872</data>
  <data key="d7">1</data>
</edge>
