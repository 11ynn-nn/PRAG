  <data key="d2">chunk-41335195b13ad0268bb37014c08227ef</data>
  <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 22}]</data>
</node>
<node id="&quot;1920S&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"The 1920s is a decade during which Broadway's music theater genre experienced remarkable artistic development and was Broadway's busiest decade."&lt;SEP&gt;"The 1920s is a period marked by remarkable artistic development in the music theater genre, particularly on Broadway."</data>
  <data key="d2">chunk-41335195b13ad0268bb37014c08227ef&lt;SEP&gt;chunk-d7778c1993fee70b814ec6d95d5a65fa</data>
