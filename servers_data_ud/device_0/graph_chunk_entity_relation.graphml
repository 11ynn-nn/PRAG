  <data key="d2">chunk-11676ae8259d9bef41b4ab8ba19335b2</data>
  <data key="d3">[{"level": 0, "cluster": 2}, {"level": 1, "cluster": 37}]</data>
</node>
<node id="&quot;CONSTANCY&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Constancy refers to the consistent behavior of body functions in the face of external disturbances, as noted by Cannon."</data>
  <data key="d2">chunk-11676ae8259d9bef41b4ab8ba19335b2</data>
  <data key="d3">[{"level": 0, "cluster": 2}, {"level": 1, "cluster": 37}]</data>
</node>
<node id="&quot;MULTIPLE COOPERATING FACTORS&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Multiple Cooperating Factors are the various elements that work together to maintain a state, as highlighted by Cannon."&lt;SEP&gt;"Multiple cooperating factors are described as acting either simultaneously or in succession to maintain a state."</data>
  <data key="d2">chunk-3d1f018f894ed3aab36e02fad8d45d76&lt;SEP&gt;chunk-11676ae8259d9bef41b4ab8ba19335b2</data>
