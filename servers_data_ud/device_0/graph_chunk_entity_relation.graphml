  <data key="d4">21.0</data>
  <data key="d5">"Weather conditions affect the hive environment and the choice of paint color for the supers."</data>
  <data key="d6">chunk-7b9cfa85a9917b7e3e3663f39bc8090b</data>
  <data key="d7">1</data>
</edge>
