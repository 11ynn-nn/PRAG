</node>
<node id="&quot;STEADY STATES&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Steady States are the stable conditions maintained by regulatory mechanisms, as described by Cannon in the context of homeostasis."</data>
  <data key="d2">chunk-11676ae8259d9bef41b4ab8ba19335b2</data>
  <data key="d3">[{"level": 0, "cluster": 2}, {"level": 1, "cluster": 37}]</data>
</node>
