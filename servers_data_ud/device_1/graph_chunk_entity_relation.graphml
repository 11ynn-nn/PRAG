<node id="&quot;CONFIDENTIALITY&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Confidentiality refers to the obligation to keep certain information secret and not disclose it to unauthorized parties."&lt;SEP&gt;"Confidentiality refers to the obligation to keep certain information secret, which the Company must adhere to."</data>
  <data key="d2">chunk-54a36509f708a00c7f0056959eeeac48&lt;SEP&gt;chunk-4c1071a343df40d56b733dc82d134dca</data>
