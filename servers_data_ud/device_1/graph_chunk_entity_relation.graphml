  <data key="d6">chunk-9761cab8f6b28df6081e9fb1a2da2a8f</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;EFFECTIVE DATE&quot;">
  <data key="d4">9.0</data>
  <data key="d5">"Company's representations and warranties are to be true and correct as of the Effective Date."</data>
  <data key="d6">chunk-0e8ce67d2107bdd08b0bb31d5ed05831</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;REPRESENTATIONS AND WARRANTIES&quot;">
  <data key="d4">9.0</data>
  <data key="d5">"Company makes representations and warranties within the agreement."</data>
  <data key="d6">chunk-0e8ce67d2107bdd08b0bb31d5ed05831</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;MATERIAL ADVERSE EFFECT&quot;">
  <data key="d4">7.0</data>
  <data key="d5">"Material Adverse Effect is a condition that would invalidate the representations and warranties if present."</data>
  <data key="d6">chunk-0e8ce67d2107bdd08b0bb31d5ed05831</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;SECTION 5.8(F)&quot;">
  <data key="d4">8.0</data>
