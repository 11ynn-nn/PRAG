  <data key="d4">14.0</data>
  <data key="d5">"B-flat3 is the starting note of the scale used to demonstrate the effect of formants on voice production."</data>
  <data key="d6">chunk-9df53a9e4f0e74a05d58e93589ff4804</data>
  <data key="d7">1</data>
</edge>
