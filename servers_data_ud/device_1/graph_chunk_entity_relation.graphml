  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Post-Employment Medical Benefits refer to health care benefits provided after employment ends, but the Company and its Subsidiaries do not provide such benefits."</data>
  <data key="d2">chunk-901cbdf0bd26b111f81dd33ee6c60d30</data>
