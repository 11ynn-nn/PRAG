</node>
<node id="&quot;NITROGEN&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Nitrogen is a component in seabird droppings that nourishes bacteria, which in turn nourishes plants."</data>
  <data key="d2">chunk-0c9f93f77f118c5c6b3d89cffbdd6bcc</data>
  <data key="d3">[{"level": 0, "cluster": 18}, {"level": 1, "cluster": 87}]</data>
</node>
<node id="&quot;ARCTIC TUNDRA&quot;">
  <data key="d0">"GEO"</data>
