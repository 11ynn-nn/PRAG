  <data key="d2">chunk-60a04f9021aa4469d11bdecb7939dedb</data>
  <data key="d3">[{"level": 0, "cluster": 10}, {"level": 1, "cluster": 68}]</data>
</node>
<node id="&quot;FORAGING&quot;">
  <data key="d0">"ACTIVITY"</data>
  <data key="d1">"Foraging is the act of bees searching for and collecting nectar from various sources."</data>
  <data key="d2">chunk-60a04f9021aa4469d11bdecb7939dedb</data>
  <data key="d3">[{"level": 0, "cluster": 10}, {"level": 1, "cluster": 68}]</data>
</node>
<node id="&quot;SIGNAL&quot;">
  <data key="d0">"ACTIVITY"</data>
