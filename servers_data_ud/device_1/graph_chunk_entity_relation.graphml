<node id="&quot;PRIVILEGED INFORMATION&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Privileged Information refers to confidential information that the Company and its Subsidiaries aim to protect."&lt;SEP&gt;"Privileged Information refers to legally protected communications that the Company is not required to disclose."</data>
  <data key="d2">chunk-54a36509f708a00c7f0056959eeeac48&lt;SEP&gt;chunk-4c1071a343df40d56b733dc82d134dca</data>
