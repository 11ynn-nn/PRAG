  <data key="d6">chunk-8ad6538dc8ba49e4be8ea60807b6b2d5</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;NO OTHER REPRESENTATIONS; NO RELIANCE&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Supporting Lenders make representations and warranties, including the event of No Other Representations; No Reliance, which confirms their compliance and adherence to the terms of the agreement."</data>
  <data key="d6">chunk-8ad6538dc8ba49e4be8ea60807b6b2d5</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;QUALIFICATION; ORGANIZATION&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Qualification; Organization is an event where the Supporting Lenders confirm their organizational status and qualification to enter into the agreement."</data>
  <data key="d6">chunk-8ad6538dc8ba49e4be8ea60807b6b2d5</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;CORPORATE AUTHORITY&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Corporate Authority is an event where the Supporting Lenders confirm their authority to enter into the agreement and perform their obligations."</data>
  <data key="d6">chunk-8ad6538dc8ba49e4be8ea60807b6b2d5</data>
  <data key="d7">1</data>
</edge>
