  <data key="d2">chunk-495e02b1ab0499af1104889b54b028c2</data>
  <data key="d3">[{"level": 0, "cluster": 11}]</data>
</node>
<node id="&quot;VEIL&quot;">
  <data key="d0">"OBJECT"</data>
  <data key="d1">"A Veil is a protective covering worn by beekeepers to prevent bee stings, which can cause discomfort and restrict movement."&lt;SEP&gt;"A veil is a protective covering worn by beekeepers to prevent stings, referenced as 'a bee inside the veil'"&lt;SEP&gt;"Veil is a protective garment worn while handling bees, costing around $60 to $75."</data>
  <data key="d2">chunk-495e02b1ab0499af1104889b54b028c2&lt;SEP&gt;chunk-e90df7de1c0152a284f55599ac2e855b&lt;SEP&gt;chunk-24ac740bd8207b788e25e1b76a32f657</data>
