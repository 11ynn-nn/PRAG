  <data key="d7">1</data>
</edge>
<edge source="&quot;VOWELS&quot;" target="&quot;SCALE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Vowels are related to the scale, which is a series of musical notes in ascending or descending order."</data>
  <data key="d6">chunk-e8e95cffe887226367f1fc5b800af6dc</data>
  <data key="d7">1</data>
</edge>
