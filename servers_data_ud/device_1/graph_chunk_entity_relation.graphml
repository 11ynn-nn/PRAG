  <data key="d6">chunk-9761cab8f6b28df6081e9fb1a2da2a8f</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;NOTIFICATION&quot;">
  <data key="d4">14.0</data>
