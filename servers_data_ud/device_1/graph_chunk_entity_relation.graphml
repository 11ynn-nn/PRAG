<node id="&quot;SMOKER&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Smoker is a tool used to calm bees before handling the hive, costing around $60 to $75."</data>
  <data key="d2">chunk-495e02b1ab0499af1104889b54b028c2</data>
  <data key="d3">[{"level": 0, "cluster": 11}]</data>
</node>
<node id="&quot;HIVE TOOL&quot;">
  <data key="d0">"ORGANIZATION"</data>
