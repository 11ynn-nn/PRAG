  <data key="d4">16.0</data>
  <data key="d5">"Debtors must follow GAAP for paying or accruing according to the agreement." )|&gt;</data>
  <data key="d6">chunk-d43b1a9be015da589b0b6eda739a9740</data>
  <data key="d7">1</data>
</edge>
