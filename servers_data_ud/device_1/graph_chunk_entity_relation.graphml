</node>
<node id="&quot;COMPLETE WITHDRAWAL&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Complete Withdrawal refers to the full withdrawal from a multiemployer plan, which the Company and its Subsidiaries have no actual or potential liability for."</data>
  <data key="d2">chunk-901cbdf0bd26b111f81dd33ee6c60d30</data>
</node>
<node id="&quot;PARTIAL WITHDRAWAL&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Partial Withdrawal refers to the partial withdrawal from a multiemployer plan, which the Company and its Subsidiaries have no actual or potential liability for."</data>
  <data key="d2">chunk-901cbdf0bd26b111f81dd33ee6c60d30</data>
</node>
<node id="&quot;ERISA&quot;">
  <data key="d0">"ORGANIZATION"</data>
