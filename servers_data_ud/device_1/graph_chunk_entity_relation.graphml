  <data key="d2">chunk-60a04f9021aa4469d11bdecb7939dedb</data>
  <data key="d3">[{"level": 0, "cluster": 10}, {"level": 1, "cluster": 68}]</data>
</node>
<node id="&quot;PLANT&quot;">
  <data key="d0">"LOCATION"</data>
  <data key="d1">"Plant is a general term for the source of nectar where bees forage."</data>
  <data key="d2">chunk-60a04f9021aa4469d11bdecb7939dedb</data>
  <data key="d3">[{"level": 0, "cluster": 10}, {"level": 1, "cluster": 68}]</data>
</node>
<node id="&quot;BEE&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Bee is an individual insect that forages for nectar and communicates with the hive."</data>
  <data key="d2">chunk-60a04f9021aa4469d11bdecb7939dedb</data>
  <data key="d3">[{"level": 0, "cluster": 10}, {"level": 1, "cluster": 68}]</data>
</node>
<node id="&quot;BLOOM&quot;">
