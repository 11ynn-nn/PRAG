  <data key="d6">chunk-36d0dcb2c223d1d1ceee0146324df75b</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;CANNON&quot;" target="&quot;GASTRIC ACTIVITY&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Cannon noticed that Gastric Activity often continues after the provoking factor is gone, suggesting a delayed response to emotional stress."</data>
  <data key="d6">chunk-36d0dcb2c223d1d1ceee0146324df75b</data>
  <data key="d7">1</data>
</edge>
