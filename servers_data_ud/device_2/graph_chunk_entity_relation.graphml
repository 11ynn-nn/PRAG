  <data key="d4">12.0</data>
  <data key="d5">"Jacob's mind shifts from the film to his research on hidden viruses, indicating a connection between his interests."</data>
  <data key="d6">chunk-494c656afa2fa45b32cf5c52326889ec</data>
  <data key="d7">1</data>
</edge>
