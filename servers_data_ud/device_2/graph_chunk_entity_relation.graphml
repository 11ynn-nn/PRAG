  <data key="d3">[{"level": 0, "cluster": 19}, {"level": 1, "cluster": 97}]</data>
</node>
<node id="&quot;REPRESSOR&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Repressor is a negative regulator of enzyme synthesis, identified as a key factor in enzyme regulation by Monod and Jacob."&lt;SEP&gt;"Repressor is a protein that keeps viral genes repressed until activated by ultraviolet light."</data>
  <data key="d2">chunk-494c656afa2fa45b32cf5c52326889ec&lt;SEP&gt;chunk-0d1852fcdaa63557848de7e718d223a6</data>
