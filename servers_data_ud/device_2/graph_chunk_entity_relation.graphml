</node>
<node id="&quot;CONSTITUTIVE MUTANTS&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Constitutive Mutants are mutants that lack a repressor of enzyme synthesis, allowing continuous enzyme synthesis without an inducer."</data>
  <data key="d2">chunk-0d1852fcdaa63557848de7e718d223a6</data>
  <data key="d3">[{"level": 0, "cluster": 19}, {"level": 1, "cluster": 97}]</data>
</node>
