  <data key="d6">chunk-6dcaa3fb65de0bc40334b1db91763464</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;THE ISLAND&quot;" target="&quot;GULF STREAM&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"The Gulf Stream affects the weather conditions on the island, bringing warm water and influencing the climate."</data>
  <data key="d6">chunk-5b8998c07aafc0d539e88b3e51f159fe</data>
  <data key="d7">1</data>
</edge>
