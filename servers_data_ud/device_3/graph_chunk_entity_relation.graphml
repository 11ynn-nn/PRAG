  <data key="d0">"LOCATION"</data>
  <data key="d1">"Crude, small town theaters are the initial venues where small time performers began their careers, serving as training grounds.")</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
</node>
<node id="&quot;FINER THEATERS IN THE BIGGEST CITIES&quot;">
  <data key="d0">"LOCATION"</data>
  <data key="d1">"Finer theaters in the biggest cities are the final venues where big time performers performed, offering the best salaries and conditions.")</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
</node>
<node id="&quot;VAUDEVILLE PERFORMER&quot;">
  <data key="d0">"ORGANIZATION"</data>
