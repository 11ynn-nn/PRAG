  <data key="d2">chunk-81ecf165e861b9b15f524411477efffe</data>
  <data key="d3">[{"level": 0, "cluster": 9}, {"level": 1, "cluster": 64}]</data>
</node>
<node id="&quot;LARVAE&quot;">
