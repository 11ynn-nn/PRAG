  <data key="d1">"Major Broadway Productions are theatrical productions known for higher admission prices compared to vaudeville shows."</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 51}, {"level": 2, "cluster": 122}]</data>
</node>
<node id="&quot;VAUDEVILLE PERFORMERS&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Vaudeville Performers are individuals who performed in vaudeville acts, often touring for at least forty weeks a year and earning salaries that were a multiple of the average factory worker's salary."</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 53}]</data>
</node>
<node id="&quot;SMALL TIME PERFORMERS&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Small Time Performers are vaudeville performers who worked in less sophisticated theaters and earned salaries ranging from fifteen to seventy dollars a week."</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 53}]</data>
</node>
<node id="&quot;MEDIUM TIME PERFORMERS&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Medium Time Performers are vaudeville performers who worked in better theaters and earned salaries that were higher than small time performers."</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 53}]</data>
</node>
<node id="&quot;BIG TIME PERFORMERS&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Big Time Performers are vaudeville performers who worked in the finest theaters and earned salaries up to $1,000 a week."</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 53}]</data>
</node>
<node id="&quot;BURLESQUE MUSICALS&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"Burlesque Musicals are a form of theatrical performance that emerged in the United States in the 1840s, characterized by parodies and travesties of famous plays, performers, or dancers."&lt;SEP&gt;"Burlesque Musicals are theatrical performances that emerged in the United States in the 1840s, distinct from vaudeville shows."</data>
  <data key="d2">chunk-9076ff576e2bf42857f37340864aa7f9&lt;SEP&gt;chunk-cd3280f423032e87d8241124c131edc6</data>
