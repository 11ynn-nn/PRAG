  <data key="d4">18.0</data>
  <data key="d5">"Bees produce honey from nectar collected and store it in the hive for future use."</data>
  <data key="d6">chunk-894b591a83b914f8f6e97ef8a4c38432</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;WAX&quot;">
