<node id="&quot;VOCAL FOLDS&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Vocal Folds are the primary structures involved in the production of sound during singing and speaking."&lt;SEP&gt;"Vocal Folds are the structures in the larynx that produce sound during singing and speaking."</data>
  <data key="d2">chunk-42e78df8d9ca72390c59785d98c0c246</data>
