  <data key="d0">"EVENT"</data>
  <data key="d1">"Defying Gravity is a song from the musical 'Wicked', performed by Idina Menzel."&lt;SEP&gt;"Defying Gravity is a song from the musical Wicked, used as an example of female belt singing."</data>
  <data key="d2">chunk-e4031c3b36282f451cd6ca67a01df325&lt;SEP&gt;chunk-42e78df8d9ca72390c59785d98c0c246</data>
