  <data key="d1">"Film is a medium for capturing and displaying moving images, which became a significant form of entertainment after the Industrial Revolution."</data>
  <data key="d2">chunk-6cc6375747c61e25b90ef2e5d1d81970</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}]</data>
</node>
<node id="&quot;TELEVISION&quot;">
