  <data key="d2">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d3">[{"level": 0, "cluster": 16}, {"level": 1, "cluster": 89}]</data>
</node>
<node id="&quot;OPERAS&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Operas are a form of theatrical performance that burlesque musicals often parodied, targeting the interests of the upper class."</data>
  <data key="d2">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d3">[{"level": 0, "cluster": 16}, {"level": 1, "cluster": 89}]</data>
