  <data key="d4">9.0</data>
  <data key="d5">"The 200-page book is logically organized around key ideas, making it easier for readers to follow the development of arguments."</data>
  <data key="d6">chunk-6f20e95f2b687a8963c77f9d1f946da0</data>
  <data key="d7">1</data>
</edge>
