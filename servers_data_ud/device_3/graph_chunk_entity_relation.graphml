  <data key="d4">6.0</data>
  <data key="d5">"President George Washington's support through theater attendance indirectly influenced the American stage by encouraging its development."</data>
  <data key="d6">chunk-0ae747ba177018e1032b8e8446ffcb86</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PRESIDENT GEORGE WASHINGTON&quot;" target="&quot;STAGE PRODUCTIONS&quot;">
  <data key="d4">16.0</data>
