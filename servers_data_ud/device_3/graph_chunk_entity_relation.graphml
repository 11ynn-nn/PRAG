  <data key="d6">chunk-bcf0c4fe6d9ae7f0f1e8ab75dc1eb4e9</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;QUEENS&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Queens are the reproductive females in a bee colony, overseeing the colony's genetic diversity."</data>
  <data key="d6">chunk-f2370a2f0c089c5553f3263304da90f0</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;WORKERS&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Workers are female bees that perform various tasks within the hive."</data>
  <data key="d6">chunk-f2370a2f0c089c5553f3263304da90f0</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;DRONES&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Drones are male bees whose primary role is to mate with the queen."</data>
  <data key="d6">chunk-f2370a2f0c089c5553f3263304da90f0</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;WEATHER&quot;">
  <data key="d4">12.0</data>
  <data key="d5">"Weather conditions, such as cool temperatures, can affect the foraging time and wax secretion of bees."</data>
  <data key="d6">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;FORAGE TIME&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Forage time is crucial for bees to gather nectar and pollen, which is necessary for wax secretion and comb building."</data>
  <data key="d6">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;HIVE&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Bees build hives using wax, which is secreted by their wax glands and stimulated by a steady supply of nectar or syrup."</data>
  <data key="d6">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;WAX GLANDS&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Wax glands in bees secrete wax, which is used to build comb and is stimulated by a steady supply of nectar or syrup."</data>
  <data key="d6">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;SYRUP&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Syrup can serve as a substitute for nectar to stimulate wax gland secretion in bees."</data>
  <data key="d6">chunk-cd3280f423032e87d8241124c131edc6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;QUEEN&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Queen is essential for the survival and growth of the Bee colony, as she lays eggs."</data>
  <data key="d6">chunk-a5249d7cd72cb7719eac165e812133b7</data>
  <data key="d7">1</data>
</edge>
