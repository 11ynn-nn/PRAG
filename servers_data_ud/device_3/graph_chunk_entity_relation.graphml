  <data key="d4">10.0</data>
  <data key="d5">"The 200-page book introduces and sets the agenda for key ideas in the new science of ecology."</data>
  <data key="d6">chunk-6f20e95f2b687a8963c77f9d1f946da0</data>
  <data key="d7">1</data>
</edge>
