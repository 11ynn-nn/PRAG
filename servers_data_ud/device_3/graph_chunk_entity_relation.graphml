  <data key="d4">10.0</data>
  <data key="d5">"The egg-laying process by the Queen is critical for the growth of the Package Colony."</data>
  <data key="d6">chunk-a5249d7cd72cb7719eac165e812133b7</data>
  <data key="d7">1</data>
</edge>
