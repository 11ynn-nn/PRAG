  <data key="d7">1</data>
</edge>
<edge source="&quot;INSTALLATION&quot;" target="&quot;THUMPING&quot;">
  <data key="d4">5.0</data>
  <data key="d5">"Thumping is a physical action used to calm the bees during the installation process."</data>
  <data key="d6">chunk-3d3ced570c1e921fa39196db14c81607</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;INSTALLATION&quot;" target="&quot;BANGING&quot;">
  <data key="d4">5.0</data>
