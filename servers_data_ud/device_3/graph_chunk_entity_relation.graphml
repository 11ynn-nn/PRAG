  <data key="d4">12.0</data>
  <data key="d5">"Absconding is a potential risk for the package colony if too much attention is given, indicating the need for careful management."</data>
  <data key="d6">chunk-3d3ced570c1e921fa39196db14c81607</data>
  <data key="d7">1</data>
</edge>
