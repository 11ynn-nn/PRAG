  <data key="d6">chunk-894b591a83b914f8f6e97ef8a4c38432</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;FOUNDATION&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Bees use Foundation as a guide to build comb, expanding the hive and storing resources."</data>
  <data key="d6">chunk-894b591a83b914f8f6e97ef8a4c38432</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;ROWLEY&quot;">
  <data key="d4">10.0</data>
