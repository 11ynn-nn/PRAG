</node>
<node id="&quot;MATING FLIGHTS&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"Mating Flights are the process where the Queen Bee leaves the hive to mate with multiple Drones."</data>
  <data key="d2">chunk-81ecf165e861b9b15f524411477efffe</data>
  <data key="d3">[{"level": 0, "cluster": 9}, {"level": 1, "cluster": 67}]</data>
</node>
<node id="&quot;COLONY MORALE&quot;">
  <data key="d0">"CONCEPT"</data>
