  <data key="d2">chunk-6cc6375747c61e25b90ef2e5d1d81970</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}]</data>
</node>
<node id="&quot;WORKING CLASS&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"The working class refers to people who work in manual or industrial jobs, often men, who were the primary audience for vaudeville."</data>
  <data key="d2">chunk-6cc6375747c61e25b90ef2e5d1d81970</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}]</data>
</node>
