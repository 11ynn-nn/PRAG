  <data key="d6">chunk-21b0db176175776d50cdbbd4696b062b</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;PROTECTING THE HIVE&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Protecting the Hive is an activity performed by Bees to safeguard the colony."</data>
  <data key="d6">chunk-21b0db176175776d50cdbbd4696b062b</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;SMOKE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Smoke is used to calm bees, reducing their agitation and making hive inspections easier."</data>
  <data key="d6">chunk-8ee60400c3602b512e18748159440dc7</data>
  <data key="d7">1</data>
</edge>
