  <data key="d6">chunk-694253136982b7320b8099c8f3c852c7</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;WILD COMB&quot;">
  <data key="d4">7.0</data>
  <data key="d5">"Wild comb affects the behavior and roles of bees within the hive."</data>
  <data key="d6">chunk-694253136982b7320b8099c8f3c852c7</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEES&quot;" target="&quot;BRIDGE COMB&quot;">
  <data key="d4">7.0</data>
