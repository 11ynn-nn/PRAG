  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 77}]</data>
</node>
<node id="&quot;SINGING VOICE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Singing Voice is the register used for singing, which is extended from the speaking voice in Female Belt Singing."</data>
