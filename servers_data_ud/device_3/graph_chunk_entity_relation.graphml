  <data key="d4">16.0</data>
  <data key="d5">"Elton's father provided some money for the expedition, showing his support and financial backing."</data>
  <data key="d6">chunk-8cac479cb6cdd8c93500916fa7e3e364</data>
  <data key="d7">1</data>
</edge>
