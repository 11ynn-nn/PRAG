  <data key="d6">chunk-aa7e3853e32e9f1fed01da5b53618aca</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;FINDER&quot;">
  <data key="d4">32.0</data>
  <data key="d5">"No Finder has been employed or engaged by the Subsidiaries for the specified transactions."&lt;&lt;SEP&gt;"The Subsidiaries have not employed or engaged any Finder for the specified transactions."&lt;</data>
  <data key="d6">chunk-aa7e3853e32e9f1fed01da5b53618aca</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;CHAPTER 11 CASES&quot;">
  <data key="d4">28.0</data>
  <data key="d5">"The Subsidiaries are involved in Chapter 11 Cases, which are an exception to the absence of pending or threatened causes of action."&lt;</data>
  <data key="d6">chunk-aa7e3853e32e9f1fed01da5b53618aca</data>
  <data key="d7">1</data>
</edge>
