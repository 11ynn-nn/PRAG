</node>
<node id="&quot;PUPAE&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Pupae are the cocooned stage of bees, which are undergoing metamorphosis to become adult bees."</data>
  <data key="d2">chunk-d9b4287519d636f7aae117d4276d53d6</data>
</node>
<node id="&quot;DEBRIS&quot;">
  <data key="d0">"OBJECT"</data>
