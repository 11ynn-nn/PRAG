  <data key="d4">10.0</data>
  <data key="d5">"Winter can cause the loss of tolerance to stings if no stings occur during this period."</data>
  <data key="d6">chunk-b932cf141ea62f3f4599201ad78d0ee1</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;TOLERANCE&quot;" target="&quot;EARLY SEASON&quot;">
  <data key="d4">12.0</data>
  <data key="d5">"The early season can help restore tolerance to stings after a winter break."</data>
  <data key="d6">chunk-b932cf141ea62f3f4599201ad78d0ee1</data>
  <data key="d7">1</data>
</edge>
