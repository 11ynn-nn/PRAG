  <data key="d4">8.0</data>
  <data key="d5">"Professional Vocal Athletes need to maintain agility to perform complex vocal techniques."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PROFESSIONAL VOCAL ATHLETES&quot;" target="&quot;FLEXIBILITY&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Professional Vocal Athletes require flexibility to execute various vocal movements smoothly."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PROFESSIONAL VOCAL ATHLETES&quot;" target="&quot;STAMINA&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Professional Vocal Athletes need stamina to sustain their performances over extended periods."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PROFESSIONAL VOCAL ATHLETES&quot;" target="&quot;POWER&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Professional Vocal Athletes must possess power to project their voices effectively."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PROFESSIONAL VOCAL ATHLETES&quot;" target="&quot;INHERENT BEAUTY&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Professional Vocal Athletes with inherent beauty in their voices are more likely to be marketable."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PROFESSIONAL VOCAL ATHLETES&quot;" target="&quot;GENRE&quot;">
  <data key="d4">8.0</data>
