  <data key="d4">8.0</data>
  <data key="d5">"Studies provide insights into Laryngeal Pathologies and their impact on Professional Vocal Athletes, emphasizing the need for proper care and management."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
