  <data key="d2">chunk-e4e181dd5099e0ad2640bc3700a9eb29</data>
</node>
<node id="&quot;STROBOSCOPIC EVALUATION&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Stroboscopic evaluation is a method used to examine the movement of the vocal folds, often revealing abnormalities in professional vocal athletes."</data>
