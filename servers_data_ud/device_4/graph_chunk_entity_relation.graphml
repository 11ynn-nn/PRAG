  <data key="d4">8.0</data>
  <data key="d5">"Professional Vocal Athletes rely on their vocal folds to produce sound, making them susceptible to abnormalities."</data>
  <data key="d6">chunk-dfad2649adb856c44a11ebf094e0805e</data>
  <data key="d7">1</data>
</edge>
