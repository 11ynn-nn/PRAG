  <data key="d4">10.0</data>
  <data key="d5">"The early season can help prevent the development of allergies if stings are experienced regularly."</data>
  <data key="d6">chunk-b932cf141ea62f3f4599201ad78d0ee1</data>
  <data key="d7">1</data>
</edge>
