  <data key="d4">36.0</data>
  <data key="d5">"The abundance of prey is crucial for the survival and growth of animals at the base of the food chain."</data>
  <data key="d6">chunk-5bc15638d83af338881cdee315b5d107</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PREY&quot;" target="&quot;PRIMARY PRODUCERS&quot;">
  <data key="d4">27.0</data>
  <data key="d5">"Prey often feed on primary producers or other organisms that consume primary producers, forming the base of the food chain."</data>
  <data key="d6">chunk-5bc15638d83af338881cdee315b5d107</data>
  <data key="d7">1</data>
</edge>
