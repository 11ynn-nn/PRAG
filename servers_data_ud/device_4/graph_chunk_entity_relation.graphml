  <data key="d2">chunk-c53f290cfdb325aa86cba150df1616e4</data>
</node>
<node id="&quot;VOICE SHIFT&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Voice Shift is the transition between vocal registers."</data>
  <data key="d2">chunk-c53f290cfdb325aa86cba150df1616e4</data>
</node>
