  <data key="d0">"LEGAL DOCUMENT"</data>
  <data key="d1">"Court orders are legal documents that guide the Company's budget and capital expenditures during a period of financial distress."</data>
  <data key="d2">chunk-5bc15638d83af338881cdee315b5d107</data>
  <data key="d3">[{"level": 0, "cluster": 1}, {"level": 1, "cluster": 24}, {"level": 2, "cluster": 90}]</data>
</node>
