  <data key="d2">chunk-e4e181dd5099e0ad2640bc3700a9eb29</data>
</node>
<node id="&quot;OVERUSE AND MISUSE INJURIES&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Overuse and misuse injuries in singers include conditions like muscle tension dysphonia, edema, and GERD, resulting from prolonged or improper use of the voice."</data>
  <data key="d2">chunk-e4e181dd5099e0ad2640bc3700a9eb29</data>
</node>
<node id="&quot;ILLNESS&quot;">
