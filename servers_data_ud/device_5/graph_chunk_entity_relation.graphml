  <data key="d4">18.0</data>
  <data key="d5">"Affiliates and their Subsidiaries are involved in the transactions and must provide information."</data>
  <data key="d6">chunk-50c13e3bb8e4150848f52b75b8673473</data>
  <data key="d7">1</data>
</edge>
