  <data key="d6">chunk-0b574feb85a5c2c80686afdf892d9573</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;HIVE&quot;" target="&quot;WEATHER&quot;">
  <data key="d4">12.0</data>
  <data key="d5">"Weather affects the hive by influencing the bees' behavior and the overall health of the colony."</data>
  <data key="d6">chunk-0b574feb85a5c2c80686afdf892d9573</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;HIVE&quot;" target="&quot;DECAY&quot;">
  <data key="d4">10.0</data>
  <data key="d5">"Decay can occur in the hive due to poor maintenance or adverse environmental conditions."</data>
  <data key="d6">chunk-0b574feb85a5c2c80686afdf892d9573</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;HIVE&quot;" target="&quot;FORAGERS&quot;">
  <data key="d4">26.0</data>
  <data key="d5">"Foragers leave the Hive to collect nectar and pollen, impacting the overall hive activity." )|&gt;&lt;SEP&gt;"The Hive is the home and workplace for Foragers, where they perform essential tasks." )|&gt;</data>
  <data key="d6">chunk-e3273db468e99ebc0efe06440d174a65</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;HIVE&quot;" target="&quot;NECTAR FLOW&quot;">
  <data key="d4">32.0</data>
  <data key="d5">"Nectar Flow affects the overall activity within the Hive." )|&gt;&lt;SEP&gt;"The Hive's activity is closely tied to the Nectar Flow, which affects the bees' behavior." )|&gt;</data>
  <data key="d6">chunk-e3273db468e99ebc0efe06440d174a65</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;HIVE&quot;" target="&quot;VENOM GLANDS&quot;">
  <data key="d4">22.0</data>
  <data key="d5">"The Hive environment can trigger the use of Venom Glands by Foragers." )|&gt;&lt;SEP&gt;"Venom Glands are used by Foragers within the Hive for defense." )|&gt;</data>
  <data key="d6">chunk-e3273db468e99ebc0efe06440d174a65</data>
  <data key="d7">1</data>
</edge>
