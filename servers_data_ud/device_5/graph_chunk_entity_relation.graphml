  <data key="d4">9.0</data>
  <data key="d5">"Supporting Lenders are provided with information about the absence of labor arbitrations, indicating stable labor relations."</data>
  <data key="d6">chunk-ee24dc1f03c4e5fa6ed654495bb59d39</data>
  <data key="d7">1</data>
</edge>
