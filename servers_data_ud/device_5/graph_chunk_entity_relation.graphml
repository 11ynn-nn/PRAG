  <data key="d3">[{"level": 0, "cluster": 2}, {"level": 1, "cluster": 23}, {"level": 2, "cluster": 51}]</data>
</node>
<node id="&quot;AGREEMENT&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"Agreement is a formal contract or arrangement between the Company and the Supporting Lenders."&lt;SEP&gt;"Agreement is the legal document that outlines the terms and conditions of the transactions between the Company and the Supporting Lenders."&lt;SEP&gt;"Agreement is the main document containing the terms and conditions of the transactions."&lt;SEP&gt;"Agreement refers to a formal contract or arrangement between the Company and the Supporting Lenders."&lt;SEP&gt;"Agreement refers to the formal arrangement or contract under Code Section 7121, involving material tax or tax returns."&lt;SEP&gt;"Agreement refers to the formal contract or document outlining the terms and conditions of the transactions between the Company and the Supporting Lenders."</data>
  <data key="d2">chunk-0888a4c0f0cc346c6d0753813ecc9e49&lt;SEP&gt;chunk-6e594c09c6de0c01da248106da72ab77&lt;SEP&gt;chunk-ff621339cc48c1d0afec4e0b8efe1d64&lt;SEP&gt;chunk-0098193a3d104a7324b88d9086bac046&lt;SEP&gt;chunk-52ea1096ae3f4e248ede1dc1be934a73&lt;SEP&gt;chunk-ee24dc1f03c4e5fa6ed654495bb59d39</data>
