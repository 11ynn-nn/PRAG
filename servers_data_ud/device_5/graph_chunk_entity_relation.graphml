<edge source="&quot;FDA&quot;" target="&quot;COMPANY&quot;">
  <data key="d4">32.0</data>
  <data key="d5">"The Company and its Subsidiaries must comply with FDA regulations to ensure the safety and effectiveness of medical devices and biological products."&lt;SEP&gt;"The Company must comply with FDA regulations to avoid invoking the policy respecting fraud and other illegal activities."</data>
  <data key="d6">chunk-9dec4a1a13d9fa1f25f4b96e1ac4a8a3&lt;SEP&gt;chunk-5042f28e2f78990ec882c0bc24a90328</data>
