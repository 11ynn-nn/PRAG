  <data key="d4">16.0</data>
  <data key="d5">"A Hive Tool is used to open hives and remove frames without damaging the hive or adjacent frames."</data>
  <data key="d6">chunk-0b574feb85a5c2c80686afdf892d9573</data>
  <data key="d7">1</data>
</edge>
