  <data key="d4">8.0</data>
  <data key="d5">"Clothing can attract bees if it carries scents such as perfume, hair spray, or after-shave lotion, making it a target for bees."</data>
  <data key="d6">chunk-a3359e9ea7553a8920a2aaf90b589a9d</data>
  <data key="d7">1</data>
</edge>
