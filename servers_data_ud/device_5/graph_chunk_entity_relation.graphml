  <data key="d4">28.0</data>
  <data key="d5">"Supporting Lenders are provided with information about employees, indicating a financial or contractual relationship."</data>
  <data key="d6">chunk-ee24dc1f03c4e5fa6ed654495bb59d39</data>
  <data key="d7">1</data>
</edge>
