  <data key="d1">"Changing material methods of accounting for tax purposes refers to altering the accounting practices that significantly affect the financial reporting and tax liability of the Company or its subsidiaries."</data>
  <data key="d2">chunk-22412b45b094ae4cf10a2ee87add10b3</data>
</node>
