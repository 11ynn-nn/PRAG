  <data key="d6">chunk-8300f5060c70067c2752417b5bf332bf</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;INTELLECTUAL PROPERTY&quot;">
  <data key="d4">16.0</data>
