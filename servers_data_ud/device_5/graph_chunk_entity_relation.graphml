  <data key="d6">chunk-05c8b19983470d6fbb9ef38e0630e896</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;COMPANY INTELLECTUAL PROPERTY&quot;">
  <data key="d4">40.0</data>
