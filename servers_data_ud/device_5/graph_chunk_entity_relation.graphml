  <data key="d4">8.0</data>
  <data key="d5">"Due Diligence involves reviewing the Subsidiaries of the Supporting Lenders."</data>
  <data key="d6">chunk-52ea1096ae3f4e248ede1dc1be934a73</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;COMPANY REGISTERED INTELLECTUAL PROPERTY&quot;">
  <data key="d4">16.0</data>
