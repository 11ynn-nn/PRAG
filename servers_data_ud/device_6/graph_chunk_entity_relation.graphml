  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"American theater refers to the theatrical productions and performances in the United States, undergoing significant changes in the mid-1860s as evidenced by the events mentioned."</data>
  <data key="d2">chunk-fb32ce27616da78546076c3f28b79293</data>
</node>
