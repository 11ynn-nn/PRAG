  <data key="d3">[{"level": 0, "cluster": 0}, {"level": 1, "cluster": 20}]</data>
</node>
<node id="&quot;TONY VOTERS&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Tony voters are the audience members who vote for Tony Awards, which recognized theatrical excellence but ignored _Hair_ in the late 1960s."</data>
  <data key="d2">chunk-aeb961c56fad5bba709f67c784ce1fa4</data>
</node>
<node id="&quot;CLIVE BARNES&quot;">
  <data key="d0">"PERSON"</data>
