</node>
<node id="&quot;CONCENTRATING ON A TASK&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"Concentrating on a task is the act of focusing on a specific task."</data>
  <data key="d2">chunk-b2c92a9c5dc2f4c6438fabee7122c013</data>
</node>
<node id="&quot;TERMINATING THE AGREEMENT&quot;">
  <data key="d0">"EVENT"</data>
