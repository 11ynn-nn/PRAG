  <data key="d0">"TECHNOLOGY"</data>
  <data key="d1">"_Our American Cousin_ is a comedy that Laura Keene performed at Ford's Theatre, where President Lincoln was assassinated."</data>
  <data key="d2">chunk-7f4321d445729e00164d7f710ea357b9</data>
