  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;HIVE ENTRANCE&quot;">
  <data key="d0">"LOCATION"</data>
  <data key="d1">"Hive entrance is the opening through which bees enter and exit the hive."&lt;SEP&gt;"Hive entrance is the point where bees collect pollen and where beekeepers collect it."</data>
