  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;BEE SUPPLY SOURCES&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Bee supply sources are places where beekeepers can purchase pollen substitutes and other beekeeping materials."</data>
  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;HONEY BEES&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Honey bees are social insects known for their complex communication methods and role in pollination."</data>
  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;COMMUNICATIONS&quot;">
  <data key="d0">"ORGANIZATION"</data>
