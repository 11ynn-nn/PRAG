  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;PATTY&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Patty is a form of pollen substitute that is moistened with syrup and fed to bees inside the hive."</data>
  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;DRY SKIM MILK&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Dry skim milk is a component of pollen substitute, providing protein and other nutrients."</data>
  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;POWDERED CASEIN&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Powdered casein is a component of pollen substitute, providing protein and other nutrients."</data>
  <data key="d2">chunk-517c563bb28c6e8e2284f65f24dada91</data>
</node>
<node id="&quot;SOY FLOUR&quot;">
  <data key="d0">"ORGANIZATION"</data>
