  <data key="d4">18.0</data>
  <data key="d5">"Workers are contained within the package, performing various tasks within the hive."&lt;SEP&gt;"Workers are contained within the package, which provides them with a temporary shelter during transportation."</data>
  <data key="d6">chunk-fb32ce27616da78546076c3f28b79293</data>
  <data key="d7">1</data>
</edge>
