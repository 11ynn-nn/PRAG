  <data key="d2">chunk-cd07e490ccf823a8fb9cd8c3c52b4240</data>
  <data key="d3">[{"level": 0, "cluster": 2}, {"level": 1, "cluster": 26}, {"level": 2, "cluster": 77}]</data>
</node>
<node id="&quot;SCIENTIFIC JOURNAL PUBLICATION&quot;">
  <data key="d0">"EVENT"</data>
