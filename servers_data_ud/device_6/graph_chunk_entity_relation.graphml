  <data key="d4">8.0</data>
  <data key="d5">"The parent queen is the original queen of the parent colony from which the bees are taken."</data>
  <data key="d6">chunk-ccf5e4489055ac80e4d05a0eafbf7b20</data>
  <data key="d7">1</data>
</edge>
