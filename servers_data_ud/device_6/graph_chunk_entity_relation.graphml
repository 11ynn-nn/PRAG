  <data key="d6">chunk-ccf5e4489055ac80e4d05a0eafbf7b20</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PACKAGE&quot;" target="&quot;PLANE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Plane is another mode of transportation used to move the package and bees during their journey."</data>
  <data key="d6">chunk-ccf5e4489055ac80e4d05a0eafbf7b20</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PACKAGE&quot;" target="&quot;TRAIN&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Train is a possible mode of transportation for the package and bees during their journey."</data>
  <data key="d6">chunk-ccf5e4489055ac80e4d05a0eafbf7b20</data>
  <data key="d7">1</data>
</edge>
