  <data key="d2">chunk-87a7ef2543aecd27dda77f210f8a31fd</data>
</node>
<node id="&quot;NEW YORK CITY&quot;">
  <data key="d0">"GEO"</data>
  <data key="d1">"New York City is a major urban center where the minstrel shows gained popularity and Laura Keene found success."&lt;SEP&gt;"New York City is a major urban center with a growing and sophisticated population demanding more complex forms of entertainment."</data>
  <data key="d2">chunk-87a7ef2543aecd27dda77f210f8a31fd&lt;SEP&gt;chunk-c327d240cc02f4086ef379cf45e3feef</data>
