</node>
<node id="&quot;PHYSICAL 'TYPING'&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Physical 'typing' refers to the physical requirements and norms for performers in music theater."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;SONGS AND ROLES&quot;">
