  <data key="d6">chunk-7f42cc300dc7597834a11cadf4d8c7c6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;WORKING HIVE&quot;" target="&quot;MANIPULATING EQUIPMENT&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Working Hive involves the task of Manipulating Equipment, which can be more labor-intensive with three boxes."</data>
  <data key="d6">chunk-7f42cc300dc7597834a11cadf4d8c7c6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;THREE BOXES&quot;" target="&quot;TWO BOXES&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Three Boxes is more labor-intensive than Two Boxes, which is a common standard in beekeeping."</data>
  <data key="d6">chunk-7f42cc300dc7597834a11cadf4d8c7c6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;THREE BOXES&quot;" target="&quot;EXTRA LABOR&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Extra Labor is associated with using Three Boxes instead of Two Boxes in beekeeping."</data>
  <data key="d6">chunk-7f42cc300dc7597834a11cadf4d8c7c6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;MINOR PROBLEMS&quot;" target="&quot;OUT OF STEP&quot;">
  <data key="d4">12.0</data>
