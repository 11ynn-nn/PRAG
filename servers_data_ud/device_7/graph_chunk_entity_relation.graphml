  <data key="d1">"Songs and roles in music theater are often learned as needed rather than beforehand."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;SOPRANO&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Soprano is the highest vocal range for females in music theater."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;ALTO&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Alto is a vocal range for females in music theater."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;TENOR&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Tenor is the highest vocal range for males in music theater."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;BARITONE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Baritone is a vocal range for males in music theater."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;ACTING&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Acting is a critical component of performance in music theater, requiring excellence."</data>
  <data key="d2">chunk-295c4464cba2eac03c733df516785973</data>
</node>
<node id="&quot;TEXT DRIVEN&quot;">
  <data key="d0">"CONCEPT"</data>
