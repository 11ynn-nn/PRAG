  <data key="d6">chunk-a0e17235a8444cecde1249732e1df0ce</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;CHEST REGISTER&quot;" target="&quot;MIDDLE C&quot;">
  <data key="d4">10.0</data>
