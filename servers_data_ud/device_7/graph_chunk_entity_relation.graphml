  <data key="d4">10.0</data>
  <data key="d5">"Reversible bottom boards can be used with either side up, while nonreversible ones have a fixed depth."</data>
  <data key="d6">chunk-fd2ef96a08268bf831497844fff694b4</data>
  <data key="d7">1</data>
</edge>
