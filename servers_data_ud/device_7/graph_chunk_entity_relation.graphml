  <data key="d6">chunk-bbe65f20246fcdba1ffce44cd00d77cc</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;WORKER BEE&quot;" target="&quot;GLANDS&quot;">
  <data key="d4">7.0</data>
