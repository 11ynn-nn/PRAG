  <data key="d2">chunk-d2310f4a93312842679f6bf2bc19bef9</data>
</node>
<node id="&quot;ICELAND&quot;">
  <data key="d0">"GEO"</data>
  <data key="d1">"Iceland is a country located in the North Atlantic where the ship took on coal."</data>
  <data key="d2">chunk-d2310f4a93312842679f6bf2bc19bef9</data>
</node>
<node id="&quot;SCORESBY SOUND&quot;">
  <data key="d0">"GEO"</data>
  <data key="d1">"Scoresby Sound is a fjord on the east coast of Greenland where the ship tried to enter but faced ice fields."</data>
  <data key="d2">chunk-d2310f4a93312842679f6bf2bc19bef9</data>
</node>
