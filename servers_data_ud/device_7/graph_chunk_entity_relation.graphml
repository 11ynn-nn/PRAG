  <data key="d6">chunk-d5b1917950dbf98fe0b5ce38e219280a</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;WORKER BEE&quot;" target="&quot;COMMUNICATION&quot;">
  <data key="d4">8.0</data>
