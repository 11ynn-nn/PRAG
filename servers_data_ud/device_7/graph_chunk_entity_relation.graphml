  <data key="d6">chunk-bbe65f20246fcdba1ffce44cd00d77cc</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;WORKER BEE&quot;" target="&quot;MUSCLES&quot;">
  <data key="d4">8.0</data>
