  <data key="d0">"LOCATION"</data>
  <data key="d1">"Sor&lt;\u00f4&gt;te is a famous seaside resort near where Jacques Monod was raised, known for its reputation as a vacation destination."</data>
  <data key="d2">chunk-4a044eb6c9ea43a457fda3a5ae087892</data>
</node>
<node id="&quot;CANNES&quot;">
  <data key="d0">"GEO"</data>
