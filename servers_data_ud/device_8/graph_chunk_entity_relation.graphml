  <data key="d2">chunk-500573969d454dad7e31832399c87294</data>
</node>
<node id="&quot;LIFE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Life refers to the state of being alive, characterized by metabolism, growth, reaction to stimuli, and reproduction."</data>
