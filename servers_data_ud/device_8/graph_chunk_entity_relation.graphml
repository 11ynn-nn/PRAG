  <data key="d6">chunk-d4ff0d3047b19e50793ea40860c34e98</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;PERSON&quot;" target="&quot;EQUITY INTERESTS&quot;">
  <data key="d4">9.0</data>
  <data key="d5">"A Person can own or control Equity Interests in a Subsidiary, as defined by the ownership or control of a majority of the voting power."</data>
  <data key="d6">chunk-78efcb7cc86e646cd522e63d35449266</data>
  <data key="d7">1</data>
</edge>
