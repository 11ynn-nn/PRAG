  <data key="d4">14.0</data>
  <data key="d5">"Cannon volunteered to serve in the Harvard Hospital Unit, a medical unit sent to Europe during World War I."</data>
  <data key="d6">chunk-f57af36635a6b8ade4cbaf6b9d73c825</data>
  <data key="d7">1</data>
</edge>
