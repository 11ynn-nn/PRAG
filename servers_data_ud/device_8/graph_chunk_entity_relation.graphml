  <data key="d6">chunk-9e973cd1cc5f8803251af14f60c371c6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;DANCE&quot;" target="&quot;ENTRANCE OF THE HIVE&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Dances are typically performed near the Entrance of the Hive."</data>
  <data key="d6">chunk-9e973cd1cc5f8803251af14f60c371c6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;DANCE&quot;" target="&quot;INFORMATION CONVEYED&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Dances like the Round Dance and Wag-Tail Dance convey specific information about nectar sources, including distance and direction."|</data>
  <data key="d6">chunk-53ba801aab88a318b172032db00d5a26</data>
  <data key="d7">1</data>
</edge>
