  <data key="d4">14.0</data>
  <data key="d5">"Additions to Tax is an event that may be included in a Tax Return."|&lt;SEP&gt;"Tax Returns may include Additions to Tax as an event."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;TAX RETURN&quot;" target="&quot;AMENDMENT&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Amendment is an event that may be included in a Tax Return."|&lt;SEP&gt;"Tax Returns may include Amendments as an event."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
