  <data key="d4">15.0</data>
  <data key="d5">"Tax Returns are filed in connection with the Restruct."|&lt;SEP&gt;"Tax Returns are part of the Restructuring process."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;TAX RETURN&quot;" target="&quot;INTEREST&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Interest is an event that may be included in a Tax Return."|&lt;SEP&gt;"Tax Returns may include Interest as an event."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;TAX RETURN&quot;" target="&quot;PENALTY&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Penalty is an event that may be included in a Tax Return."|&lt;SEP&gt;"Tax Returns may include Penalty as an event."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
