  <data key="d4">16.0</data>
  <data key="d5">"Ecological overshoot affects the functioning of organisms, which is studied by physiologists."</data>
  <data key="d6">chunk-86f3f3c15069861d2c2d1799514caa1a</data>
  <data key="d7">1</data>
</edge>
