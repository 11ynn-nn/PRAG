  <data key="d4">14.0</data>
  <data key="d5">"Combined Tax Return is a type of return that may be included in a Tax Return."|&lt;SEP&gt;"Tax Returns may include Combined Tax Returns as a type of return."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;TAX RETURN&quot;" target="&quot;UNITARY TAX RETURN&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Tax Returns may include Unitary Tax Returns as a type of return."|&lt;SEP&gt;"Unitary Tax Return is a type of return that may be included in a Tax Return."|</data>
  <data key="d6">chunk-2c97437b365f5eb5e2f2cc5e0ff5a3ec</data>
  <data key="d7">1</data>
</edge>
