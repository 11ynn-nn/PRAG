  <data key="d4">8.0</data>
  <data key="d5">"The c-abl protein's 'head' is fused to the bcr protein's 'tail' to create the bcr/abl fusion protein."</data>
  <data key="d6">chunk-4808624bb772962b1d285e9a96aaec01</data>
  <data key="d7">1</data>
</edge>
