  <data key="d0">"EVENT"</data>
  <data key="d1">"Rock/Pop Musical represents a new era in musical theater composition that began with the success of Hair and continues to evolve over fifty years, characterized by amplified singing and electric instruments."</data>
  <data key="d2">chunk-0267286c81e05982bbb46c95364cbb30</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}, {"level": 2, "cluster": 126}]</data>
