  <data key="d7">1</data>
</edge>
<edge source="&quot;TAKEOVER STATUTE&quot;" target="&quot;MORATORIUM LAW&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Moratorium Law is part of the broader Takeover Statute, designed to temporarily halt certain actions during a takeover."</data>
  <data key="d6">chunk-4f5291955ed514f3c0e0eb381e9616fe</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;TAKEOVER STATUTE&quot;" target="&quot;CONTROL SHARE ACQUISITION LAW&quot;">
  <data key="d4">16.0</data>
