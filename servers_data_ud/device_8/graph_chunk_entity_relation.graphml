  <data key="d2">chunk-a5a56afe52a888e5c4267f47f027e036</data>
  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;SEASON&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Season refers to the time of the year, which affects the duration and frequency of beekeeper visits."&lt;SEP&gt;"Seasons are mentioned as factors affecting the type and level of activity in the colony throughout the year."</data>
