  <data key="d4">18.0</data>
  <data key="d5">"c- _abl_ gene is found in the human genome."</data>
  <data key="d6">chunk-d0cf0b37864347226f145a22592586fb</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;C- _ABL_ GENE&quot;" target="&quot;DUTCH AND BRITISH RESEARCHERS&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Dutch and British researchers studied the c- _abl_ gene and its location on chromosome 9."</data>
  <data key="d6">chunk-d0cf0b37864347226f145a22592586fb</data>
  <data key="d7">1</data>
</edge>
