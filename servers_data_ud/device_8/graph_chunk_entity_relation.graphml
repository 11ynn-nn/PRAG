  <data key="d4">8.0</data>
  <data key="d5">"Beeswax Production is the activity performed by worker bees to produce the material used in constructing the honeycomb."|</data>
  <data key="d6">chunk-53ba801aab88a318b172032db00d5a26</data>
  <data key="d7">1</data>
</edge>
