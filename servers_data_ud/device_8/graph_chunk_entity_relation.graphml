  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Minimization refers to reducing or managing factors that can negatively impact vocal health, such as dehydration or excessive strain."</data>
  <data key="d2">chunk-a51071d5167d43f8855eef4ba001dbe8</data>
  <data key="d3">[{"level": 0, "cluster": 16}, {"level": 1, "cluster": 84}, {"level": 2, "cluster": 146}, {"level": 3, "cluster": 148}]</data>
