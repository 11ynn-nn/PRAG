  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Thick and Sticky Mucus is a condition where mucus becomes viscous and less effective in lubricating the vocal folds."</data>
  <data key="d2">chunk-48744b276bffa8148a6398e5afebc9e2</data>
  <data key="d3">[{"level": 0, "cluster": 16}, {"level": 1, "cluster": 82}]</data>
