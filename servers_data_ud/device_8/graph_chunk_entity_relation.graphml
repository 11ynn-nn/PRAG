  <data key="d2">chunk-0267286c81e05982bbb46c95364cbb30</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}, {"level": 2, "cluster": 127}]</data>
</node>
<node id="&quot;POP/ROCK STYLE&quot;">
  <data key="d0">"TECHNOLOGY"</data>
  <data key="d1">"Pop/Rock Style is the dominant form used by music theater composers today, requiring singers to perform in the belt range at higher pitch levels."</data>
  <data key="d2">chunk-0267286c81e05982bbb46c95364cbb30</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}, {"level": 2, "cluster": 127}]</data>
</node>
<node id="&quot;BELT RANGE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Belt Range is a vocal technique used in pop/rock musicals, particularly for females, involving higher pitch levels beyond the C4–C5 range."</data>
  <data key="d2">chunk-0267286c81e05982bbb46c95364cbb30</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 55}, {"level": 2, "cluster": 127}]</data>
