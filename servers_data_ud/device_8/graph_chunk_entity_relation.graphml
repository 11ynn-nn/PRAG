  <data key="d4">7.0</data>
  <data key="d5">"Sunlight helps bees orient the Figure-Eight Pattern in the Wag-Tail Dance to convey direction information."|</data>
  <data key="d6">chunk-53ba801aab88a318b172032db00d5a26</data>
  <data key="d7">1</data>
</edge>
