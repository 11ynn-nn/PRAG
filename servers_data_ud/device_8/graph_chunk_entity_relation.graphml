  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;YEAR-ROUND ACTIVITY&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Year-Round Activity refers to the continuous nature of honey bee colony activity, with periods of relative inactivity but no true hibernation."</data>
  <data key="d2">chunk-a40a756fcfe048bdd7aa9b2b44a0469e</data>
  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;ADEQUATE FOOD RESERVES&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Adequate Food Reserves are necessary for maintaining a healthy honey bee colony, ensuring survival through periods of low forage availability."</data>
  <data key="d2">chunk-a40a756fcfe048bdd7aa9b2b44a0469e</data>
  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;NORMAL FORAGE AVAILABILITY&quot;">
  <data key="d0">"CONCEPT"</data>
