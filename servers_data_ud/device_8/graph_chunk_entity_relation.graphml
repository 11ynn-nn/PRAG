</node>
<node id="&quot;MYC GENE&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"MYC gene is a cellular proto-oncogene that can become an oncogene when mutated, often found in tumor viruses and associated with cancer development."</data>
  <data key="d2">chunk-a5a3865eb058f0b3cc7bdbd824f201bd</data>
  <data key="d3">[{"level": 0, "cluster": 8}, {"level": 1, "cluster": 58}]</data>
