  <data key="d2">chunk-a40a756fcfe048bdd7aa9b2b44a0469e</data>
  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;LOCAL VARIATIONS&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Local Variations reflect the differences in the annual population cycle of a honey bee colony based on specific geographic and environmental conditions."</data>
  <data key="d2">chunk-a40a756fcfe048bdd7aa9b2b44a0469e</data>
  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;SHORT-TERM VARIABILITY&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Short-Term Variability indicates the fluctuations in the honey bee colony's population and activity levels within a given year, influenced by immediate environmental conditions."</data>
  <data key="d2">chunk-a40a756fcfe048bdd7aa9b2b44a0469e</data>
  <data key="d3">[{"level": 0, "cluster": 13}, {"level": 1, "cluster": 78}]</data>
</node>
<node id="&quot;LOW POINT IN POPULATION&quot;">
