  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not fully engage with state beekeeper organizations."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;NATIONAL BEEKEEPER ORGANIZATION&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not fully engage with national beekeeper organizations."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;BEEKEEPERS' CLUB OR ASSOCIATION&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not fully engage with beekeepers' clubs or associations."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;BEEKEEPERS' MAGAZINE&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not fully engage with beekeepers' magazines."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;BEE&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may have bees but lack proper care."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;ENTHUSIASM&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may lack initial enthusiasm."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;REGULAR BASIS&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers do not keep bees on a regular basis."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;ENJOYMENT&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not enjoy beekeeping."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;CONTACT&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not have adequate contact with other beekeepers or resources."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;SOURCES OF NEW DEVELOPMENTS&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not stay updated on new developments."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;REGULATIONS&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not follow regulations."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;NEWS&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not stay informed about news."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;EVENTS&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not participate in events."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;COMMUNITY SUPPORT&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not have community support."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEHAVER&quot;" target="&quot;REGULAR READING&quot;">
  <data key="d4">6.0</data>
  <data key="d5">"Beehavers may not read regularly."</data>
  <data key="d6">chunk-2bd4cd24e118c8cfdf44ccab7c205d81</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEKEEPERS' CLUB OR ASSOCIATION&quot;" target="&quot;NATIONAL BEEKEEPER ORGANIZATIONS&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"National beekeeper organizations and local beekeepers' clubs or associations are interconnected, with the former providing broader support and the latter offering localized assistance."</data>
  <data key="d6">chunk-4957ec7ee118ac56c14f04d82744a8e6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEKEEPERS' CLUB OR ASSOCIATION&quot;" target="&quot;BEEKEEPERS' MAGAZINE&quot;">
  <data key="d4">12.0</data>
  <data key="d5">"Local beekeepers' clubs or associations may recommend or distribute beekeepers' magazines to their members, fostering a community of learning and support."</data>
  <data key="d6">chunk-4957ec7ee118ac56c14f04d82744a8e6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEEKEEPERS' MAGAZINE&quot;" target="&quot;NATIONAL BEEKEEPER ORGANIZATIONS&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"National beekeeper organizations often collaborate with publishers of beekeepers' magazines to disseminate information and resources to a wider audience."</data>
  <data key="d6">chunk-4957ec7ee118ac56c14f04d82744a8e6</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;STINGING&quot;">
  <data key="d4">56.0</data>
  <data key="d5">"Bee performs stinging as a defensive mechanism in response to perceived threats or attacks."&lt;SEP&gt;"Bees perform stinging as a defensive mechanism in response to perceived threats or attacks."&lt;SEP&gt;"Stinging is a defensive action performed by bees in response to perceived threats or attacks."&lt;SEP&gt;"Stinging is a defensive action performed by bees in response to perceived threats."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3&lt;SEP&gt;chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;NOSE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Bee can perceive the nose as an aggressive action."</data>
  <data key="d6">chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;FLOWER&quot;">
  <data key="d4">24.0</data>
  <data key="d5">"Bee can perceive the flower as a threat."&lt;SEP&gt;"Bees perceive flowers as a source of nectar and may view human proximity to flowers as an attack."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3&lt;SEP&gt;chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;NECTAR&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Bee can perceive the nectar as a threat."</data>
  <data key="d6">chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;ATTACK&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Bee can perceive an attack as a threat."</data>
  <data key="d6">chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;HOME&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Bee can perceive the home as a protected area."</data>
  <data key="d6">chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;HIVE&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Bees defend their hives aggressively and can become more reactive if the hive is subjected to harassment."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;SWATTING&quot;">
  <data key="d4">20.0</data>
  <data key="d5">"Swatting is a clear aggressive action that can trigger a defensive reaction in bees."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;VANDALISM&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Vandalism can provoke bees to become more reactive due to perceived harassment."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;ANIMAL DEPREDATION&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Animal depredation can make bees more reactive due to perceived harassment."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;BODY CHEMISTRY&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Body chemistry can affect how bees react to humans, either provoking or calming them."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;FRAGRANCE&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Fragrances can attract or repel bees based on their scent."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;HUMAN PROXIMITY&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Human proximity can be perceived as a threat by bees, especially if it is sudden or aggressive."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;DEFENSIVE REACTION&quot;">
  <data key="d4">20.0</data>
  <data key="d5">"Defensive reaction is a behavior exhibited by bees in response to perceived threats."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;PERCEIVED AGGRESSION&quot;">
  <data key="d4">20.0</data>
  <data key="d5">"Perceived aggression is any action or presence that triggers a defensive response in bees."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;BENIGN INTENTIONS&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Benign intentions refer to actions that are not meant to harm but can still trigger a defensive reaction in bees."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;PERSISTENT ANNOYANCE&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Persistent annoyance is a repeated action that can make bees more reactive over time."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;BEE&quot;" target="&quot;MEDICAL ADVICE&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Medical advice can lead some people to believe they are allergic to bee stings, even if they are not."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
