  <data key="d4">16.0</data>
  <data key="d5">"Federal research facilities and colleges/universities collaborate in developing agricultural components and offering educational programs in beekeeping."</data>
  <data key="d6">chunk-90bb6316aa4aebbba7c436b6735776e9</data>
  <data key="d7">1</data>
</edge>
