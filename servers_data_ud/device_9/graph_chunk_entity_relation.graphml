  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;PROMPT WRITTEN NOTICE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders must provide prompt written notice to the Company of certain events."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;OCCURRENCE, OR FAILURE TO OCCUR, OF ANY EVENT&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders must notify the Company of the occurrence or failure to occur of any event that may affect the agreement."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;MATERIAL BREACH OF ANY COVENANT&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders must notify the Company of any material breach of any covenant."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;EVENT, CONDITION, FACT, OR CIRCUMSTANCE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders must notify the Company of any event, condition, fact, or circumstance that may impact the timely satisfaction of conditions set forth in the agreement."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
