  <data key="d4">8.0</data>
  <data key="d5">"The presence of sugar in the feeder induces wax secretion in bees, which is an activity in response to an adequate food supply."</data>
  <data key="d6">chunk-1a10e4014c4f193eee14a336747f04aa</data>
  <data key="d7">1</data>
</edge>
