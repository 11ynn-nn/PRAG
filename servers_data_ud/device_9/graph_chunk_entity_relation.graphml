  <data key="d4">9.0</data>
  <data key="d5">"Subsidiaries must possess all necessary Business Permits to operate legally, and these permits must be valid and in full force and effect."</data>
  <data key="d6">chunk-a3118a5b7ebfcd2e890ae61fb2869a29</data>
  <data key="d7">1</data>
</edge>
