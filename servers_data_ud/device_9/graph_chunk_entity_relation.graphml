  <data key="d4">17.0</data>
  <data key="d5">"The Supporting Lenders are responsible for ensuring that Lender Specified Representations remain true and accurate."&lt;SEP&gt;"The Supporting Lenders must ensure that Lender Specified Representations remain true and accurate throughout the agreement."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
