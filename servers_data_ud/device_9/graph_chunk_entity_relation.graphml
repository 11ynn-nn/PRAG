  <data key="d3">[{"level": 0, "cluster": 9}, {"level": 1, "cluster": 49}]</data>
</node>
<node id="&quot;APICULTURE&quot;">
  <data key="d0">"ACTIVITY"</data>
  <data key="d1">"Apiculture is the scientific study and management of honey bees, which has greatly improved over time."</data>
  <data key="d2">chunk-90bb6316aa4aebbba7c436b6735776e9</data>
</node>
<node id="&quot;INDUSTRIAL REVOLUTION&quot;">
  <data key="d0">"EVENT"</data>
  <data key="d1">"The Industrial Revolution significantly impacted beekeeping by changing attitudes and lifestyles, leading to the evolution of beekeeper types."</data>
  <data key="d2">chunk-90bb6316aa4aebbba7c436b6735776e9</data>
  <data key="d3">[{"level": 0, "cluster": 9}, {"level": 1, "cluster": 51}]</data>
</node>
<node id="&quot;HOBBYIST OR BACKYARDER&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Hobbyist or backyard beekeepers are individuals who keep one to twenty hives for various reasons, not primarily for income."</data>
  <data key="d2">chunk-90bb6316aa4aebbba7c436b6735776e9</data>
  <data key="d3">[{"level": 0, "cluster": 9}, {"level": 1, "cluster": 51}]</data>
</node>
<node id="&quot;SIDELINER&quot;">
  <data key="d0">"PERSON"</data>
  <data key="d1">"Sideliners are beekeepers who operate as a small sideline business, using bees as a supplementary source of income."</data>
  <data key="d2">chunk-90bb6316aa4aebbba7c436b6735776e9</data>
  <data key="d3">[{"level": 0, "cluster": 9}, {"level": 1, "cluster": 51}]</data>
</node>
