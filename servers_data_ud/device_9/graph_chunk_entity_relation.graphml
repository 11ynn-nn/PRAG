  <data key="d4">16.0</data>
  <data key="d5">"Wellness: Injury Prevention focuses on preventing vocal injuries, making it directly related to the prevention of vocal disorders."</data>
  <data key="d6">chunk-7f6dfd6cf19346b800ac411171835010</data>
  <data key="d7">1</data>
</edge>
