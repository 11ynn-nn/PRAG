  <data key="d4">16.0</data>
  <data key="d5">"Swelling and pain are physical reactions that can occur after a bee sting, even if the person is not truly allergic."</data>
  <data key="d6">chunk-35887a077ff8cc664c022e0850b536e3</data>
  <data key="d7">1</data>
</edge>
