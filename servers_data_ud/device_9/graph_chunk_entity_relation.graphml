<node id="&quot;HOBBYISTS&quot;">
  <data key="d0">"ORGANIZATION"</data>
  <data key="d1">"Hobbyists are new beekeepers who approach beekeeping in a relaxed, casual manner, finding it enjoyable but potentially disappointing without proper commitment."</data>
  <data key="d2">chunk-2ff401080e75bc199ec4bbb83221e314</data>
</node>
<node id="&quot;INSTRUCTOR&quot;">
  <data key="d0">"PERSON"</data>
