  <data key="d6">chunk-32b75be069c2e11b99b8211d14f57d5a</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;FEEDBACK INHIBITION&quot;" target="&quot;ALLOSTERIC REGULATION&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"Allosteric Regulation is the mechanism behind Feedback Inhibition, where inhibitors alter enzyme shape to prevent substrate binding."</data>
  <data key="d6">chunk-95d378a4a5d837b5df62cf1349844f34</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;ENZYME&quot;" target="&quot;SUBSTRATE&quot;">
  <data key="d4">32.0</data>
  <data key="d5">"Enzyme acts on substrate, specifically mentioned in the context of fitting into an active site."&lt;SEP&gt;"Substrates bind to the active site of enzymes to undergo chemical reactions."</data>
  <data key="d6">chunk-95d378a4a5d837b5df62cf1349844f34&lt;SEP&gt;chunk-3a1fe5c5c561e507d8c235678840d518</data>
