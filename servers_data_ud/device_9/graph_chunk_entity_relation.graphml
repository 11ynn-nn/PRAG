  <data key="d4">14.0</data>
  <data key="d5">"Threonine is a substrate that fits into the active site of the enzyme, while Isoleucine inhibits the enzyme, highlighting their contrasting roles."</data>
  <data key="d6">chunk-3a1fe5c5c561e507d8c235678840d518</data>
  <data key="d7">1</data>
</edge>
