  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders must comply with the conditions set by the Effective Date."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
