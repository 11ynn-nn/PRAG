  <data key="d7">1</data>
</edge>
<edge source="&quot;STINGING&quot;" target="&quot;FLOWER&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Stinging is a defensive action triggered by the presence of a flower, which can be perceived as a threat by a bee."</data>
  <data key="d6">chunk-78ab64a815cd3d2a836336392f2eca48</data>
  <data key="d7">1</data>
</edge>
