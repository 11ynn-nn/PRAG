  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders must comply with their covenants as outlined in the Agreement."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;CONDITIONS SET FORTH IN ARTICLE III&quot;">
  <data key="d4">16.0</data>
  <data key="d5">"The Supporting Lenders must comply with the conditions set forth in Article III to satisfy the requirements for certain actions to proceed."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
