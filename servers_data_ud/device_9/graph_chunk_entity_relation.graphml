  <data key="d6">chunk-a6fe41559fa35bb0034a3d53d2587c5f</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;DEFINITIVE DOCUMENTS&quot;" target="&quot;RESTRUCTURING&quot;">
  <data key="d4">18.0</data>
  <data key="d5">"Definitive Documents formalize the terms of the Restructuring process."</data>
  <data key="d6">chunk-a6fe41559fa35bb0034a3d53d2587c5f</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;DEFINITIVE DOCUMENTS&quot;" target="&quot;SUPPORTING LENDERS&quot;">
  <data key="d4">49.0</data>
  <data key="d5">"Supporting Lenders are involved in the negotiations and coordination of the Definitive Documents."&lt;SEP&gt;"The Supporting Lenders are responsible for negotiating Definitive Documents in good faith."&lt;SEP&gt;"The Supporting Lenders monitor the consistency of the Definitive Documents with the Restructuring Term Sheet."</data>
