  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;PALPABLE SILENCE&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders experience a palpable silence as they reflect on their role and the implications of their actions."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;MESSAGE FROM THE HEAVENS&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders receive and respond to the message from the heavens."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;OPERATION&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders are engaged in the operation to communicate and respond to the message from the heavens."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;DARING, A TONE SET NOT BY THE EARTHLY&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders adopt a daring tone in their actions, not constrained by conventional earthly norms."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;COLLECTIVE ACTION&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders take collective action in response to the message from the heavens."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
