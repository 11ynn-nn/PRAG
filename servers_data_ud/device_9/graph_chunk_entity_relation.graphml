  <data key="d4">18.0</data>
  <data key="d5">"Wellness: Injury Prevention aims to understand and prevent voice disorders, making these two concepts closely related."</data>
  <data key="d6">chunk-7f6dfd6cf19346b800ac411171835010</data>
  <data key="d7">1</data>
</edge>
