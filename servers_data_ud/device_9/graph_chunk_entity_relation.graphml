  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;DARING&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"The Supporting Lenders exhibit a daring approach in their actions and responses."</data>
  <data key="d6">chunk-a98abc7661191612db1330d484a309bd</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUPPORTING LENDERS&quot;" target="&quot;NEW FREQUENCY&quot;">
  <data key="d4">8.0</data>
