  <data key="d4">8.0</data>
  <data key="d5">"Each Party is released from its commitments and can take actions related to Restructuring, as outlined in the agreement."</data>
  <data key="d6">chunk-f1048bb352f0f09318b7c1004aeb9e1d</data>
  <data key="d7">1</data>
</edge>
