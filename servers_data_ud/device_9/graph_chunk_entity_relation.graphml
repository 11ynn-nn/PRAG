  <data key="d4">15.0</data>
  <data key="d5">"Bees can indicate the shortest straight-line distance even if the actual route must vary to avoid an obstruction."&lt;&lt;SEP&gt;"Bees indicate the shortest straight-line distance even if the actual route varies to avoid obstructions."&lt;</data>
  <data key="d6">chunk-752a4bcfd49e3f7ebeb351081eb4553f</data>
  <data key="d7">1</data>
</edge>
