</node>
<node id="&quot;Β-GALACTOSIDASE&quot;">
  <data key="d0">"ENZYME"</data>
  <data key="d1">"β-galactosidase is an enzyme whose synthesis is regulated by lactose and the repressor protein."</data>
  <data key="d2">chunk-babaf934dcb765f08d028d1b33488eef</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 43}]</data>
</node>
