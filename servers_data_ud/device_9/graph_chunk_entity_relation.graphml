  <data key="d4">15.0</data>
  <data key="d5">"Bees adjust their dance to account for the effects of crosswinds."&lt;&lt;SEP&gt;"Bees can adjust their dance to account for the effects of a crosswind on the flight path to the forage site."&lt;</data>
  <data key="d6">chunk-752a4bcfd49e3f7ebeb351081eb4553f</data>
  <data key="d7">1</data>
</edge>
