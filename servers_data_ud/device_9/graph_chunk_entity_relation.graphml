  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;DEFINITIVE DOCUMENTS&quot;">
  <data key="d4">44.0</data>
  <data key="d5">"Company agrees to negotiate in good faith all Definitive Documents during the Restructuring process."&lt;SEP&gt;"The Company must ensure that the Definitive Documents are consistent with the Restructuring Term Sheet."&lt;SEP&gt;"The Definitive Documents must be consistent with the Restructuring Term Sheet, and any inconsistencies must be corrected within three Business Days."</data>
  <data key="d6">chunk-d5417895366679d5abd3d326e6c67df2&lt;SEP&gt;chunk-497066cb85846685befbf13ad5fbcafa</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;COMPANY&quot;" target="&quot;SUBSIDIARIES&quot;">
  <data key="d4">84.0</data>
  <data key="d5">"Company directs its Subsidiaries to participate in the Restructuring process during the Effective Period."&lt;SEP&gt;"Subsidiaries are part of the Company and must comply with the same conditions and possess necessary permits as the main Company."&lt;SEP&gt;"Subsidiaries are part of the Company and must comply with the same conditions and regulations as the Company."&lt;SEP&gt;"The Company mentioned in the text has Subsidiaries that are subject to various legal and regulatory requirements."</data>
  <data key="d6">chunk-a3118a5b7ebfcd2e890ae61fb2869a29&lt;SEP&gt;chunk-d5417895366679d5abd3d326e6c67df2&lt;SEP&gt;chunk-ecc6c7a82dfa782ad734c65afdc66563&lt;SEP&gt;chunk-9c27bf2a240355db951cca111fcbf0b4</data>
