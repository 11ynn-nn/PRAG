  <data key="d4">7.0</data>
  <data key="d5">"Research conducted at Federal Research Facilities contributed to the growth of Commercial Operations in beekeeping."</data>
  <data key="d6">chunk-cea2d10b8f63096775e979aa558ddd87</data>
  <data key="d7">1</data>
</edge>
