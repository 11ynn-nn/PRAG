<node id="&quot;DOUBLE-NEGATIVE LOGIC&quot;">
  <data key="d0">"CONCEPT"</data>
  <data key="d1">"Double-Negative Logic is the logical principle that explains the regulation of enzyme synthesis by lactose and the repressor protein."</data>
  <data key="d2">chunk-babaf934dcb765f08d028d1b33488eef</data>
  <data key="d3">[{"level": 0, "cluster": 7}, {"level": 1, "cluster": 43}]</data>
