  <data key="d4">7.0</data>
  <data key="d5">"Subsidiaries are not allowed to make contributions to Domestic or Foreign Political Parties or Candidates unless it is not material."</data>
  <data key="d6">chunk-a3118a5b7ebfcd2e890ae61fb2869a29</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;UNLAWFUL BRIBES, KICKBACKS&quot;">
  <data key="d4">10.0</data>
  <data key="d5">"Subsidiaries must avoid engaging in Unlawful Bribes, Kickbacks as they are illegal financial transactions."</data>
  <data key="d6">chunk-a3118a5b7ebfcd2e890ae61fb2869a29</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;MATERIAL ADVERSE EFFECT&quot;">
  <data key="d4">8.0</data>
  <data key="d5">"Subsidiaries must ensure that any actions do not result in a Material Adverse Effect on their operations or financial status."</data>
  <data key="d6">chunk-a3118a5b7ebfcd2e890ae61fb2869a29</data>
  <data key="d7">1</data>
</edge>
<edge source="&quot;SUBSIDIARIES&quot;" target="&quot;AFFILIATES&quot;">
  <data key="d4">14.0</data>
  <data key="d5">"Affiliates are related organizations that are associated with the Company and its Subsidiaries, and their compliance is also important."&lt;SEP&gt;"Affiliates are related organizations that are associated with the Company, and their compliance is also important."</data>
  <data key="d6">chunk-a3118a5b7ebfcd2e890ae61fb2869a29</data>
  <data key="d7">1</data>
</edge>
